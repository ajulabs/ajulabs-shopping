{
  "name": "ajulabs-monorepo",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "consumer": "pnpm --filter consumer start",
    "lojista": "pnpm --filter lojista start",
    "entregador": "pnpm --filter entregador start",
    "consumer:android": "pnpm --filter consumer android",
    "consumer:ios": "pnpm --filter consumer ios",
    "typecheck": "pnpm -r run typecheck",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prepare": "husky",
    "lint": "pnpm --filter backend run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,json}\" --ignore-path .prettierignore",
    "postinstall": "node scripts/patch-maplibre-codegen.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "apps/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "packages/**/*.{ts,tsx}": [
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "dependencies": {
    "expo": "~54.0.34",
    "react": "19.1.0",
    "react-native": "0.81.5"
  }
}
