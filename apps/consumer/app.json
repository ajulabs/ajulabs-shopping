{
  "expo": {
    "name": "Shopping Digital AjuLabs",
    "slug": "ajulabs-shopping",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000933"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ajulabs.shopping"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000933"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.ajulabs.shopping",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "react-native-maps"
    ],
    "scheme": "ajulabs",
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5320400-8dd2-4590-8714-0fff0af7d42d"
      }
    }
  }
}