{
  "expo": {
    "name": "AjuLabs Lojista",
    "slug": "ajulabs-lojista",
    "version": "0.0.1",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ajulabs.lojista"
    },
    "android": {
      "package": "com.ajulabs.lojista"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para atualizar imagem da loja",
          "cameraPermission": "Permitir acesso à câmera para fotografar a loja"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#000933"
        }
      ]
    ],
    "scheme": "ajulabs-lojista"
  }
}