{
  "expo": {
    "name": "AjuLabs Lojista",
    "slug": "ajulabs-lojista",
    "version": "0.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.ajulabs.lojista"
    },
    "android": {
      "package": "com.ajulabs.lojista",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000933"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "@maplibre/maplibre-react-native",
      [
        "expo-image-picker",
        {
          "photosPermission": "Permitir acesso às fotos para atualizar imagem da loja",
          "cameraPermission": "Permitir acesso à câmera para fotografar a loja"
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#000933"
        }
      ]
    ],
    "scheme": "ajulabs-lojista",
    "extra": {
      "eas": {
        "projectId": "ee478d9e-4ac0-4181-a841-6b158cfde24c"
      }
    }
  }
}