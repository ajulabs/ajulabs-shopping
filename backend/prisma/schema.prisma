generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// 1. AUTENTICAÇÃO & IDENTIDADE
// ========================================

model Usuario {
  id                  String   @id @default(uuid())
  nome                String
  cpf                 String   @unique
  telefone            String   @unique
  email               String   @unique
  senhaHash           String   @map("senha_hash")
  avatarUrl           String?  @map("avatar_url")
  telefoneVerificado  Boolean  @default(false) @map("telefone_verificado")
  criadoEm            DateTime @default(now()) @map("criado_em")
  atualizadoEm        DateTime @updatedAt @map("atualizado_em")

  enderecos              EnderecoUsuario[]
  pedidos                Pedido[]
  conversas              ConversaChat[]
  avaliacoes             AvaliacaoLoja[]
  avaliacoesEntregador   AvaliacaoEntregador[]
  avaliacoesProdutos     AvaliacaoProduto[]
  supportTickets         SupportTicket[]
  favoritos              FavoritoProduto[]
  favoritosLojas         FavoritoLoja[]
  dispositivosPush       DispositivoPush[]
  prefsOptOut            PreferenciaNotificacaoOptOut[]
  tokensRecuperacao      TokenRecuperacaoSenha[]

  @@map("usuarios")
}

model TokenRecuperacaoSenha {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  codigo    String
  expiresAt DateTime @map("expires_at")
  usado     Boolean  @default(false)
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("tokens_recuperacao_senha")
}

model DispositivoPush {
  id            String   @id @default(uuid())
  consumidorId  String?  @map("consumidor_id")
  lojistaId     String?  @map("lojista_id")
  entregadorId  String?  @map("entregador_id")
  expoToken     String   @unique @map("expo_token")
  plataforma    String?
  appTipo       String   @default("consumer") @map("app_tipo")
  ativo         Boolean  @default(true)
  criadoEm      DateTime @default(now()) @map("criado_em")
  atualizadoEm  DateTime @updatedAt @map("atualizado_em")

  consumidor Usuario?    @relation(fields: [consumidorId], references: [id], onDelete: Cascade)
  lojista    Lojista?    @relation(fields: [lojistaId], references: [id], onDelete: Cascade)
  entregador Entregador? @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@index([consumidorId, ativo])
  @@index([lojistaId, ativo])
  @@index([entregadorId, ativo])
  @@map("dispositivos_push")
}

enum TipoTransporte {
  bike
  moto
  carro
}

enum StatusConta {
  pendente
  ativo
  suspenso
}

model Entregador {
  id             String         @id @default(uuid())
  nome           String
  cpf            String         @unique
  telefone       String         @unique
  email          String         @unique
  senhaHash      String         @map("senha_hash")
  fotoUrl        String?        @map("foto_url")
  tipoTransporte TipoTransporte @map("tipo_transporte")
  statusConta    StatusConta    @default(pendente) @map("status_conta")
  online         Boolean        @default(false)
  /**
   * Última posição reportada pelo app quando o entregador está online.
   * Atualizada via POST /v1/entregador/heartbeat aproximadamente a cada
   * 1 minuto. Permite ao backend ofertar corridas para os entregadores
   * mais próximos sem depender de socket aberto.
   */
  ultimaLat      Float?         @map("ultima_lat")
  ultimaLng      Float?         @map("ultima_lng")
  ultimoHeartbeat DateTime?     @map("ultimo_heartbeat")
  avaliacao      Float          @default(0)
  totalAvaliacoes Int           @default(0) @map("total_avaliacoes")
  criadoEm       DateTime       @default(now()) @map("criado_em")
  atualizadoEm   DateTime       @updatedAt @map("atualizado_em")

  documentos            DocumentoEntregador?
  veiculo               VeiculoEntregador?
  dadosBancarios        DadosBancariosEntregador?
  entregas              EntregaRealizada[]
  pedidos               Pedido[]
  saques                SolicitacaoSaque[]
  solicitacoesTrocaVeiculo SolicitacaoTrocaVeiculo[]
  dispositivosPush      DispositivoPush[]
  prefsOptOut           PreferenciaNotificacaoOptOut[]
  avaliacoes            AvaliacaoEntregador[]

  @@map("entregadores")
}

model Lojista {
  id              String   @id @default(uuid())
  cnpj            String   @unique
  nomeResponsavel String   @map("nome_responsavel")
  email           String   @unique
  senhaHash       String   @map("senha_hash")
  telefone        String
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  lojas            Loja[]
  dispositivosPush DispositivoPush[]
  prefsOptOut      PreferenciaNotificacaoOptOut[]

  @@map("lojistas")
}

model PreferenciaNotificacaoOptOut {
  id            String   @id @default(uuid())
  consumidorId  String?  @map("consumidor_id")
  lojistaId     String?  @map("lojista_id")
  entregadorId  String?  @map("entregador_id")
  categoria     String
  criadoEm      DateTime @default(now()) @map("criado_em")

  consumidor Usuario?    @relation(fields: [consumidorId], references: [id], onDelete: Cascade)
  lojista    Lojista?    @relation(fields: [lojistaId], references: [id], onDelete: Cascade)
  entregador Entregador? @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@unique([consumidorId, categoria])
  @@unique([lojistaId, categoria])
  @@unique([entregadorId, categoria])
  @@index([consumidorId])
  @@index([lojistaId])
  @@index([entregadorId])
  @@map("preferencias_notificacao_opt_out")
}

// ========================================
// 2. DOCUMENTAÇÃO DO ENTREGADOR
// ========================================

enum StatusDocumento {
  pendente
  aprovado
  rejeitado
}

model DocumentoEntregador {
  id           String          @id @default(uuid())
  entregadorId String          @unique @map("entregador_id")
  frenteUrl    String          @map("frente_url")
  versoUrl     String          @map("verso_url")
  status       StatusDocumento @default(pendente)
  revisadoEm   DateTime?       @map("revisado_em")
  criadoEm     DateTime        @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@map("documentos_entregador")
}

model VeiculoEntregador {
  id           String   @id @default(uuid())
  entregadorId String   @unique @map("entregador_id")
  placa        String
  modelo       String
  cor          String
  ano          Int
  criadoEm     DateTime @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@map("veiculos_entregador")
}

enum StatusTrocaVeiculo {
  pendente
  aprovado
  rejeitado
}

model SolicitacaoTrocaVeiculo {
  id             String             @id @default(uuid())
  entregadorId   String             @map("entregador_id")
  tipoTransporte TipoTransporte     @map("tipo_transporte")
  modelo         String
  placa          String
  cor            String
  ano            Int
  cnhUrl         String?            @map("cnh_url")
  docVeiculoUrl  String?            @map("doc_veiculo_url")
  status         StatusTrocaVeiculo @default(pendente)
  criadoEm       DateTime           @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@map("solicitacoes_troca_veiculo")
}

enum TipoDadosBancarios {
  pix
  conta
}

model DadosBancariosEntregador {
  id           String             @id @default(uuid())
  entregadorId String             @unique @map("entregador_id")
  tipo         TipoDadosBancarios
  chavePix     String?            @map("chave_pix")
  banco        String?
  agencia      String?
  conta        String?
  criadoEm     DateTime           @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id], onDelete: Cascade)

  @@map("dados_bancarios_entregador")
}

// ========================================
// 3. LOJA
// ========================================

model Loja {
  id                 String   @id @default(uuid())
  lojistaId          String   @map("lojista_id")
  nome               String
  descricao          String
  categoria          String
  logoUrl            String?  @map("logo_url")
  bannerUrl          String?  @map("banner_url")
  telefone           String
  whatsapp           String?
  avaliacao          Decimal  @default(0) @db.Decimal(2, 1)
  totalAvaliacoes    Int      @default(0) @map("total_avaliacoes")
  tempoEntregaMin    Int      @map("tempo_entrega_min")
  tempoEntregaMax    Int      @map("tempo_entrega_max")
  taxaEntrega        Decimal  @map("taxa_entrega") @db.Decimal(10, 2)
  aberta             Boolean  @default(true)
  aceitaAgendamento  Boolean  @default(false) @map("aceita_agendamento")
  antecedenciaMinima Int?     @map("antecedencia_minima")
  criadoEm           DateTime @default(now()) @map("criado_em")
  atualizadoEm       DateTime @updatedAt @map("atualizado_em")

  lojista              Lojista                @relation(fields: [lojistaId], references: [id], onDelete: Cascade)
  endereco             EnderecoLoja?
  horarios             HorarioFuncionamento[]
  produtos             Produto[]
  pedidos              Pedido[]
  avaliacoes           AvaliacaoLoja[]
  supportTickets       SupportTicket[]
  favoritos            FavoritoLoja[]
  movimentacoesEstoque MovimentacaoEstoque[]
  colaboradores        Colaborador[]
  solicitacoesPreco    SolicitacaoPreco[]

  @@map("lojas")
}

model EnderecoLoja {
  id          String   @id @default(uuid())
  lojaId      String   @unique @map("loja_id")
  rua         String
  numero      String
  bairro      String
  cep         String
  cidade      String
  complemento String?
  lat         Float?
  lng         Float?
  accuracy    Int?
  geoSource   String?  @map("geo_source")
  criadoEm    DateTime @default(now()) @map("criado_em")

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@map("enderecos_loja")
}

model HorarioFuncionamento {
  id         String   @id @default(uuid())
  lojaId     String   @map("loja_id")
  diaSemana  Int      @map("dia_semana")
  ativo      Boolean  @default(true)
  abertura   String
  fechamento String
  criadoEm   DateTime @default(now()) @map("criado_em")

  loja Loja @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@map("horarios_funcionamento")
}

// ========================================
// 4. CATÁLOGO
// ========================================

model Categoria {
  id    String @id @default(uuid())
  nome  String @unique
  emoji String

  @@map("categorias")
}

model Produto {
  id            String                      @id @default(uuid())
  lojaId        String                      @map("loja_id")
  nome          String
  descricao     String
  preco         Decimal                     @db.Decimal(10, 2)
  estoque       Int
  estoqueMinimo Int                         @default(0) @map("estoque_minimo")
  imagemUrl     String                      @map("imagem_url")
  imagens       String[]                    @default([])
  categoria     String
  tags          String[]
  disponivel    Boolean                     @default(true)
  destaque      Boolean                     @default(false)
  avaliacao     Float                       @default(0)
  totalAvaliacoes Int                       @default(0) @map("total_avaliacoes")
  embedding     Unsupported("vector(1536)")?
  criadoEm      DateTime                    @default(now()) @map("criado_em")
  atualizadoEm  DateTime                    @updatedAt @map("atualizado_em")

  loja              Loja                  @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  variacoes         VariacaoProduto[]
  itens             ItemPedido[]
  sugestoes         SugestaoProdutoChat[]
  favoritos         FavoritoProduto[]
  movimentacoes     MovimentacaoEstoque[]
  avaliacoes        AvaliacaoProduto[]
  solicitacoesPreco SolicitacaoPreco[]

  @@map("produtos")
}

model VariacaoProduto {
  id        String   @id @default(uuid())
  produtoId String   @map("produto_id")
  nome      String
  estoque   Int
  preco     Decimal? @db.Decimal(10, 2)

  produto Produto      @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  itens   ItemPedido[]

  @@map("variacoes_produto")
}

model FavoritoLoja {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  lojaId    String   @map("loja_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  loja    Loja    @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, lojaId])
  @@map("favoritos_loja")
}

model FavoritoProduto {
  id        String   @id @default(uuid())
  usuarioId String   @map("usuario_id")
  produtoId String   @map("produto_id")
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, produtoId])
  @@map("favoritos_produto")
}

// ========================================
// 5. ENDEREÇOS DO CONSUMIDOR
// ========================================

model EnderecoUsuario {
  id          String   @id @default(uuid())
  usuarioId   String   @map("usuario_id")
  apelido     String
  rua         String
  numero      String
  bairro      String
  cep         String
  cidade      String
  complemento String?
  padrao      Boolean  @default(false)
  lat         Float?
  lng         Float?
  accuracy    Int?
  geoSource   String?  @map("geo_source")
  criadoEm    DateTime @default(now()) @map("criado_em")

  usuario Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  pedidos Pedido[]

  @@map("enderecos_usuario")
}

// ========================================
// 6. PEDIDOS
// ========================================

enum StatusPedido {
  aguardando
  confirmado
  preparando
  pronto
  saiu_entrega
  entregue
  cancelado
}

enum MetodoPagamento {
  pix
  cartao
}

model Pedido {
  id                String          @id @default(uuid())
  consumidorId      String          @map("consumidor_id")
  lojaId            String          @map("loja_id")
  entregadorId      String?         @map("entregador_id")
  enderecoEntregaId String          @map("endereco_entrega_id")
  status            StatusPedido    @default(aguardando)
  metodoPagamento   MetodoPagamento @map("metodo_pagamento")
  subtotal          Decimal         @db.Decimal(10, 2)
  taxaEntrega       Decimal         @map("taxa_entrega") @db.Decimal(10, 2)
  desconto          Decimal         @default(0) @db.Decimal(10, 2)
  total             Decimal         @db.Decimal(10, 2)
  obs               String?
  codigoEntrega     String?         @map("codigo_entrega")
  estimativaEntrega DateTime?       @map("estimativa_entrega")
  avaliado          Boolean         @default(false)
  criadoEm          DateTime        @default(now()) @map("criado_em")
  atualizadoEm      DateTime        @updatedAt @map("atualizado_em")

  consumidor          Usuario                 @relation(fields: [consumidorId], references: [id])
  loja                Loja                    @relation(fields: [lojaId], references: [id])
  entregador          Entregador?             @relation(fields: [entregadorId], references: [id])
  enderecoEntrega     EnderecoUsuario         @relation(fields: [enderecoEntregaId], references: [id])
  itens               ItemPedido[]
  historico           HistoricoStatusPedido[]
  pagamento           Pagamento?
  entregaRealizada    EntregaRealizada?
  avaliacao           AvaliacaoLoja?
  avaliacaoEntregador AvaliacaoEntregador?
  avaliacoesProdutos  AvaliacaoProduto[]
  supportTickets      SupportTicket[]
  chat                ChatPedido?

  @@map("pedidos")
}

model ItemPedido {
  id            String  @id @default(uuid())
  pedidoId      String  @map("pedido_id")
  produtoId     String  @map("produto_id")
  variacaoId    String? @map("variacao_id")
  nomeSnapshot  String  @map("nome_snapshot")
  variacaoNome  String? @map("variacao_nome")
  precoUnitario Decimal @map("preco_unitario") @db.Decimal(10, 2)
  quantidade    Int

  pedido   Pedido           @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produto  Produto          @relation(fields: [produtoId], references: [id])
  variacao VariacaoProduto? @relation(fields: [variacaoId], references: [id])

  @@map("itens_pedido")
}

model HistoricoStatusPedido {
  id       String       @id @default(uuid())
  pedidoId String       @map("pedido_id")
  status   StatusPedido
  criadoEm DateTime     @default(now()) @map("criado_em")

  pedido Pedido @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@map("historico_status_pedido")
}

// ========================================
// 7. ESTOQUE — MOVIMENTAÇÕES
// ========================================

enum TipoMovimentacao {
  entrada_manual
  saida_manual
  venda
  cancelamento
  devolucao
  ajuste_inventario
  reserva
  liberacao_reserva
}

model MovimentacaoEstoque {
  id            String           @id @default(uuid())
  produtoId     String           @map("produto_id")
  lojaId        String           @map("loja_id")
  lojistaId     String?          @map("lojista_id")
  tipo          TipoMovimentacao
  quantidade    Int
  estoqueAntes  Int              @map("estoque_antes")
  estoqueDepois Int              @map("estoque_depois")
  motivo        String?
  pedidoId      String?          @map("pedido_id")
  criadoEm      DateTime         @default(now()) @map("criado_em")

  produto Produto  @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  loja    Loja     @relation(fields: [lojaId], references: [id], onDelete: Cascade)

  @@index([lojaId, criadoEm(sort: Desc)])
  @@index([produtoId, criadoEm(sort: Desc)])
  @@map("movimentacoes_estoque")
}

// ========================================
// 8. CHAT / IA
// ========================================

model ConversaChat {
  id           String    @id @default(uuid())
  usuarioId    String    @map("usuario_id")
  criadaEm     DateTime  @default(now()) @map("criada_em")
  atualizadoEm DateTime  @updatedAt @map("atualizado_em")
  estado       Json?

  usuario   Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  mensagens MensagemChat[]

  @@map("conversas_chat")
}

enum RemetenteChat {
  usuario
  aju
}

model MensagemChat {
  id         String        @id @default(uuid())
  conversaId String        @map("conversa_id")
  remetente  RemetenteChat
  conteudo   String
  criadaEm   DateTime      @default(now()) @map("criada_em")

  conversa  ConversaChat          @relation(fields: [conversaId], references: [id], onDelete: Cascade)
  sugestoes SugestaoProdutoChat[]

  @@map("mensagens_chat")
}

model SugestaoProdutoChat {
  id         String    @id @default(uuid())
  mensagemId String    @map("mensagem_id")
  produtoId  String    @map("produto_id")
  clicadoEm DateTime? @map("clicado_em")

  mensagem MensagemChat @relation(fields: [mensagemId], references: [id], onDelete: Cascade)
  produto  Produto      @relation(fields: [produtoId], references: [id])

  @@map("sugestoes_produto_chat")
}

enum TicketStatus {
  aberto
  em_andamento
  resolvido
  cancelado
}

model SupportTicket {
  id           String       @id @default(uuid())
  consumidorId String       @map("consumidor_id")
  pedidoId     String?      @map("pedido_id")
  lojaId       String?      @map("loja_id")
  motivo       String
  protocolo    String       @unique
  status       TicketStatus @default(aberto)
  urgente      Boolean      @default(false)
  criadoEm     DateTime     @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  avaliacaoConsumidor Int? @map("avaliacao_consumidor")

  consumidor Usuario          @relation(fields: [consumidorId], references: [id])
  pedido     Pedido?          @relation(fields: [pedidoId], references: [id])
  loja       Loja?            @relation(fields: [lojaId], references: [id])
  notas      TicketNota[]
  mensagens  TicketMensagem[]

  @@map("support_tickets")
}

model TicketMensagem {
  id        String   @id @default(uuid())
  ticketId  String   @map("ticket_id")
  remetente String
  texto     String
  criadoEm  DateTime @default(now()) @map("criado_em")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_mensagens")
}

model TicketNota {
  id        String        @id @default(uuid())
  ticketId  String        @map("ticket_id")
  texto     String
  criadoEm  DateTime      @default(now()) @map("criado_em")

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@map("ticket_notas")
}

// ========================================
// 8. CHAT ENTRE PARTICIPANTES DO PEDIDO
// ========================================

enum TipoParticipanteChat {
  CONSUMER
  LOJISTA
  ENTREGADOR
}

enum StatusChatPedido {
  ativo
  encerrado
}

model ChatPedido {
  id        String           @id @default(uuid())
  pedidoId  String           @unique @map("pedido_id")
  status    StatusChatPedido @default(ativo)
  criadoEm  DateTime         @default(now()) @map("criado_em")

  pedido    Pedido               @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  mensagens ChatMensagemPedido[]

  @@map("chats_pedido")
}

model ChatMensagemPedido {
  id               String               @id @default(uuid())
  chatId           String               @map("chat_id")
  conteudo         String
  remetenteType    TipoParticipanteChat @map("remetente_type")
  remetenteId      String               @map("remetente_id")
  destinatarioType TipoParticipanteChat @map("destinatario_type")
  destinatarioId   String               @map("destinatario_id")
  lido             Boolean              @default(false)
  criadoEm         DateTime             @default(now()) @map("criado_em")

  chat ChatPedido @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([chatId, criadoEm])
  @@index([destinatarioId, destinatarioType, lido])
  @@map("chat_mensagens_pedido")
}

// ========================================
// 9. GANHOS DO ENTREGADOR
// ========================================

model EntregaRealizada {
  id            String   @id @default(uuid())
  entregadorId  String   @map("entregador_id")
  pedidoId      String   @unique @map("pedido_id")
  valorRecebido Decimal  @map("valor_recebido") @db.Decimal(10, 2)
  bonus         Decimal? @db.Decimal(10, 2)
  criadoEm      DateTime @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id])
  pedido     Pedido     @relation(fields: [pedidoId], references: [id])

  @@map("entregas_realizadas")
}

// ========================================
// 9. AVALIAÇÕES
// ========================================

model AvaliacaoLoja {
  id         String   @id @default(uuid())
  lojaId     String   @map("loja_id")
  usuarioId  String   @map("usuario_id")
  pedidoId   String   @unique @map("pedido_id")
  nota       Int
  comentario String?
  /**
   * Tags estruturadas marcadas pelo cliente na avaliação.
   * Catálogo fechado mantido em packages/types/src/index.ts (TAGS_AVALIACAO_LOJA).
   * Permite agregar "Pontos fortes" e "Pontos a melhorar" no dashboard do lojista
   * sem precisar fazer NLP no comentário livre.
   */
  tags       String[] @default([])
  criadoEm   DateTime @default(now()) @map("criado_em")

  loja    Loja    @relation(fields: [lojaId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@map("avaliacoes_loja")
}

model AvaliacaoEntregador {
  id           String   @id @default(uuid())
  entregadorId String   @map("entregador_id")
  usuarioId    String   @map("usuario_id")
  pedidoId     String   @unique @map("pedido_id")
  nota         Int
  comentario   String?
  /** Mesmo conceito de AvaliacaoLoja.tags. Catálogo em TAGS_AVALIACAO_ENTREGADOR. */
  tags         String[] @default([])
  criadoEm     DateTime @default(now()) @map("criado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id])
  usuario    Usuario    @relation(fields: [usuarioId], references: [id])
  pedido     Pedido     @relation(fields: [pedidoId], references: [id])

  @@map("avaliacoes_entregador")
}

model AvaliacaoProduto {
  id         String   @id @default(uuid())
  produtoId  String   @map("produto_id")
  usuarioId  String   @map("usuario_id")
  pedidoId   String   @map("pedido_id")
  nota       Int
  comentario String?
  criadoEm   DateTime @default(now()) @map("criado_em")

  produto Produto @relation(fields: [produtoId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])
  pedido  Pedido  @relation(fields: [pedidoId], references: [id])

  @@unique([produtoId, pedidoId])
  @@map("avaliacoes_produto")
}

// ========================================
// 10. PAGAMENTOS
// ========================================

enum StatusPagamento {
  pendente
  aprovado
  falhou
  estornado
}

model Pagamento {
  id        String          @id @default(uuid())
  pedidoId  String          @unique @map("pedido_id")
  metodo    MetodoPagamento
  status    StatusPagamento @default(pendente)
  valor     Decimal         @db.Decimal(10, 2)
  gatewayId String?         @map("gateway_id")
  criadoEm  DateTime        @default(now()) @map("criado_em")

  pedido Pedido @relation(fields: [pedidoId], references: [id])

  @@map("pagamentos")
}

// ========================================
// 11. SAQUES DO ENTREGADOR
// ========================================

enum StatusSaque {
  solicitado
  processando
  concluido
  falhou
}

model SolicitacaoSaque {
  id           String      @id @default(uuid())
  entregadorId String      @map("entregador_id")
  valor        Decimal     @db.Decimal(10, 2)
  chavePix     String      @map("chave_pix")
  status       StatusSaque @default(solicitado)
  criadoEm    DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime   @updatedAt @map("atualizado_em")

  entregador Entregador @relation(fields: [entregadorId], references: [id])

  @@map("solicitacoes_saque")
}

// ========================================
// 12. RBAC — COLABORADORES & AUDITORIA
// ========================================

enum PapelColaborador {
  admin
  gerente
  funcionario
}

enum StatusSolicitacaoPreco {
  pendente
  aprovado
  rejeitado
}

model Colaborador {
  id           String           @id @default(uuid())
  lojaId       String           @map("loja_id")
  nome         String
  email        String           @unique
  senhaHash    String           @map("senha_hash")
  papel        PapelColaborador @default(funcionario)
  ativo        Boolean          @default(true)
  criadoEm     DateTime         @default(now()) @map("criado_em")
  atualizadoEm DateTime         @updatedAt @map("atualizado_em")

  loja                 Loja               @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  solicitacoesEnviadas SolicitacaoPreco[] @relation("Solicitante")

  @@index([lojaId])
  @@map("colaboradores")
}

model SolicitacaoPreco {
  id              String                 @id @default(uuid())
  produtoId       String                 @map("produto_id")
  lojaId          String                 @map("loja_id")
  solicitanteId   String                 @map("solicitante_id")
  precoAtual      Decimal                @map("preco_atual") @db.Decimal(10, 2)
  precoSolicitado Decimal                @map("preco_solicitado") @db.Decimal(10, 2)
  justificativa   String
  status          StatusSolicitacaoPreco @default(pendente)
  revisadoPorId   String?                @map("revisado_por_id")
  revisadoPorTipo String?                @map("revisado_por_tipo")
  revisadoPorNome String?                @map("revisado_por_nome")
  revisadoEm      DateTime?              @map("revisado_em")
  notaRevisao     String?                @map("nota_revisao")
  criadoEm        DateTime               @default(now()) @map("criado_em")

  produto     Produto     @relation(fields: [produtoId], references: [id], onDelete: Cascade)
  loja        Loja        @relation(fields: [lojaId], references: [id], onDelete: Cascade)
  solicitante Colaborador @relation("Solicitante", fields: [solicitanteId], references: [id])

  @@index([lojaId, status])
  @@index([solicitanteId])
  @@map("solicitacoes_preco")
}

model AuditLog {
  id         String   @id @default(uuid())
  timestamp  DateTime @default(now())
  lojaId     String   @map("loja_id")
  actorId    String   @map("actor_id")
  actorTipo  String   @map("actor_tipo")
  actorNome  String   @map("actor_nome")
  actorPapel String   @map("actor_papel")
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  entityName String   @map("entity_name")
  changes    Json?
  ipAddress  String?  @map("ip_address")

  @@index([lojaId, timestamp(sort: Desc)])
  @@index([actorId])
  @@map("audit_logs")
}
