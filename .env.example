# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
# URL de conexão pooled (usado pelo Prisma em runtime)
DATABASE_URL=postgresql://user:password@host:5432/ajulabs

# URL direta (usada pelo Prisma Migrate — sem pooler)
DIRECT_URL=postgresql://user:password@host:5432/ajulabs

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Mínimo 32 caracteres. Gere com: openssl rand -hex 32
JWT_SECRET=troque_por_uma_string_aleatoria_de_no_minimo_32_chars
JWT_REFRESH_SECRET=troque_por_outra_string_aleatoria_de_no_minimo_32_chars

# ─── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ─── Supabase (Storage) ───────────────────────────────────────────────────────
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula
# Em dev pode deixar vazio (libera tudo). Em produção, especifique explicitamente.
ALLOWED_ORIGINS=http://localhost:8081,http://localhost:3001

# ─── Slack (opcional) ─────────────────────────────────────────────────────────
# Webhook para notificações de novos tickets de suporte
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ─── Apps (Expo) ─────────────────────────────────────────────────────────────
# Usado pelos apps React Native para apontar para o backend
EXPO_PUBLIC_API_URL=http://localhost:3000
